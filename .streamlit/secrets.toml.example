# ===================================================
# このファイルを secrets.toml にコピーして値を設定してください
# secrets.toml は .gitignore に含まれており Git にコミットされません
# ===================================================

# Anthropic API Key (必須)
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxx"

# アプリのセキュリティキー (必ずランダムな文字列に変更)
SECRET_KEY = "change-this-to-a-random-secret-key"

# Claude モデル設定
CLAUDE_MODEL = "claude-sonnet-4-6"

# 管理者設定
ADMIN_DEFAULT_PASSWORD = "ここに強力なパスワードを設定"
ADMIN_EMAIL = "admin@androots.co.jp"

# 許可メールドメイン (カンマ区切りで複数指定可能)
# 例: "androots.co.jp" → @androots.co.jp のみ
# 例: "androots.co.jp, example.com" → 両ドメインを許可
ALLOWED_EMAIL_DOMAINS = "androots.co.jp"

# --- SMTP メール送信設定 (必須) ---
# Gmail の場合: アプリパスワードを使用してください
# https://myaccount.google.com/apppasswords
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "your-email@gmail.com"
SMTP_PASSWORD = "your-app-password"
SMTP_FROM = "your-email@gmail.com"

# アプリの公開URL (認証リンク生成に使用)
# Streamlit Community Cloud の場合: https://your-app.streamlit.app
APP_URL = ""

# --- Notion 連携 (任意) ---
# トークン節約のため Notion からデータを取得する場合に設定
# https://www.notion.so/my-integrations でインテグレーション作成
NOTION_API_KEY = ""
NOTION_DATABASE_ID = ""
