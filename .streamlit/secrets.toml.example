# ===================================================
# このファイルを secrets.toml にコピーして値を設定してください
# secrets.toml は .gitignore に含まれており Git にコミットされません
# ===================================================

# Anthropic API Key (必須)
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxx"

# アプリのセキュリティキー (ランダムな文字列に変更してください)
SECRET_KEY = "change-this-to-a-random-secret-key"

# Claude モデル設定
CLAUDE_MODEL = "claude-sonnet-4-6"

# 管理者の初期パスワード (初回起動後に変更推奨)
ADMIN_DEFAULT_PASSWORD = "ここに強力なパスワードを設定"
