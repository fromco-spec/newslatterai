# ===================================================
# このファイルを .env にコピーして値を設定してください
# .env は .gitignore に含まれており Git にコミットされません
# ===================================================

# Anthropic API Key (必須)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# セキュリティキー (必ずランダムな文字列に変更してください)
# 生成例: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-to-a-random-secret-key

# Claude モデル設定
CLAUDE_MODEL=claude-sonnet-4-6

# 管理者の初期パスワード (必須・初回起動後にUIから変更推奨)
ADMIN_DEFAULT_PASSWORD=change-this-password

# 管理者メールアドレス
ADMIN_EMAIL=admin@androots.co.jp

# --- SMTP メール送信設定 (必須) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# アプリの公開URL (認証リンク生成に使用・空欄なら認証コード方式)
APP_URL=
